# ORVANTA Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://warops:warops_secret@postgres:5432/warops_db
DATABASE_URL_SYNC=postgresql://warops:warops_secret@postgres:5432/warops_db
POSTGRES_USER=warops
POSTGRES_PASSWORD=warops_secret
POSTGRES_DB=warops_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_CHAT_MODEL=llama3.1:8b

# Free-first AI providers
AI_CHAT_PROVIDER_ORDER=groq,openrouter,nvidia,ollama,local
AI_CHAT_HISTORY_LIMIT=8
AI_CHAT_MAX_TOKENS=420
AI_CHAT_TIMEOUT_SECONDS=45
AI_CHAT_TEMPERATURE=0.2
OLLAMA_CHAT_ATTEMPT_TIMEOUT_SECONDS=12
AI_CHAT_ENABLE_WEB_CONTEXT=true
AI_CHAT_WEB_MAX_RESULTS=4
AI_CHAT_WEB_LOOKUP_TIMEOUT_SECONDS=10

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-20b

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# SMTP (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@orvanta.local
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=

# ACLED (optional - uses simulated data if not set)
ACLED_API_KEY=
ACLED_EMAIL=

# GDELT
GDELT_ENABLED=true
AUTO_INGEST_ENABLED=false
LIVE_SYNC_AUTO_ENABLED=true
LIVE_SYNC_AUTO_INTERVAL_SECONDS=300

# App
APP_NAME=ORVANTA
APP_ENV=development
APP_DEBUG=true
SQL_ECHO=false
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8080"]
API_V1_PREFIX=/api/v1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/api/v1/ws
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
NEXT_PUBLIC_CLERK_ORG_ID=
CLERK_DEFAULT_ORG_ID=
